# ── InvestX for Agents — environment ─────────────────────────────────────────
# Keys never appear in models or logs. Signing happens wallet/local side only.

# ── Identity (ERC-8004) ──────────────────────────────────────────────────────
# This agent's OWN registered agentId. Leave unset until you have run
# erc8004-register; until then a provisional id is used and records are stamped
# agentIdProvisional:true. NEVER set this to 55560 (that is AA's id).
INVESTX_AGENT_ID=

# ── x402 payment — Base (EVM) ────────────────────────────────────────────────
# EVM signing backend: "privatekey" (default) or "circle".
SIGNER_BACKEND=privatekey
PAYMENT_PRIVATE_KEY=            # 0x-prefixed 64-hex key (holds USDC on Base mainnet)

# Circle DCW (only when SIGNER_BACKEND=circle, and for ERC-8004 register/set-uri)
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=          # 32-byte hex, registered in Circle dashboard
CIRCLE_EVM_WALLET_ID=
CIRCLE_EVM_WALLET_ADDRESS=     # 0x...

# ── x402 payment — Solana (optional; SVM exact via @x402/svm) ─────────────────
# base58-encoded 64-byte keypair. If unset, Solana endpoints are skipped.
SOLANA_PRIVATE_KEY=
SOLANA_WALLET_ADDRESS=
SOLANA_MAX_USDC_MICRO=1000000  # per-payment cap, micro-USDC (default $1.00)

# Circle Solana transfer path (only if you route Solana payments via Circle DCW)
CIRCLE_SOLANA_WALLET_ID=

# ── Input endpoints (URLs copied from AA; override if they move) ──────────────
YIELD_INTELLIGENCE_URL=        # default: https://x402yi.vercel.app/api/yield/scan   ($0.20)
PORTFOLIO_INTELLIGENCE_URL=    # default: https://x402pi.vercel.app/api/portfolio/analyze ($0.50, POST)

# Portfolio Intelligence analyses this wallet (the operator's own, non-custodial)
INVESTX_PORTFOLIO_TARGET=      # 0x... or Solana address
INVESTX_PORTFOLIO_CHAIN=base

# ── Decision config ──────────────────────────────────────────────────────────
MANDATE_PATH=                  # default: ./mandate.yaml
INVESTX_START_VALUE_USD=       # baseline for the drawdown brake (else inferred from log)

# ── Safety ───────────────────────────────────────────────────────────────────
# Live execution is structurally blocked until this is true (see safety/execute-guard).
# Only set after confirming the execute path returns a real on-chain tx (not a stub).
INVESTX_EXECUTE_PATH_VERIFIED=false

# ── Record store (Upstash Redis REST; optional — local JSONL is always written) ─
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Notifications (optional; only brakes notify) ─────────────────────────────
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# ── HTTP server ──────────────────────────────────────────────────────────────
PORT=3000
RAILWAY_PUBLIC_DOMAIN=         # set by Railway; used in the agent card URL
INVESTX_PUBLIC_URL=            # public base URL when not on Railway
