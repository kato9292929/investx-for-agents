# ── InvestX for Agents — environment ─────────────────────────────────────────
# No payment/signing keys. Inputs are DeFiLlama (free) + Nansen (apiKey header).

# ── Identity (ERC-8004) ──────────────────────────────────────────────────────
# This agent's own agentId. Unset => a provisional id is used and records are
# stamped agentIdProvisional:true. Never set this to 55560 (that is AA's id).
INVESTX_AGENT_ID=

# ── Inputs: DeFiLlama (free, no key) ─────────────────────────────────────────
LLAMA_POOLS_URL=               # default: https://yields.llama.fi/pools
LLAMA_CHART_BASE=              # default: https://yields.llama.fi/chart  (24h TVL brake)
INVESTX_CHAIN=Solana           # DeFiLlama chain filter

# ── Inputs: Nansen (apiKey) ──────────────────────────────────────────────────
NANSEN_API_KEY=                # required for smart money; absent => "スマートマネー確認なし"
NANSEN_HOLDINGS_URL=           # default: https://api.nansen.ai/api/v1/smart-money/holdings

# ── Current allocation: local holdings file (no self-hosted endpoint) ────────
# Absent => portfolio recorded as unknown (never dummy). See config/holdings.example.json
INVESTX_HOLDINGS_PATH=         # default: ./config/holdings.json
INVESTX_START_VALUE_USD=       # baseline for the drawdown brake (else inferred from log)

# ── Decision config ──────────────────────────────────────────────────────────
MANDATE_PATH=                  # default: ./mandate.yaml

# ── Record store (Upstash Redis REST; optional — local JSONL always written) ──
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Notifications (optional; only brakes notify) ─────────────────────────────
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# ── Execution: Kamino in-wallet rebalance (v1; off by default) ───────────────
# Safety switch. Only "true" allows a REAL mainnet send. Default/false => the
# path stops after simulate (no send). Leave false until a simulate has passed.
EXECUTE_ENABLED=false
# The InvestX-dedicated wallet 6WyH... as solana id.json bytes (JSON array of 64).
# Never a new/generated key here — startup asserts the address equals 6WyH...
SOLANA_KEYPAIR=
SOLANA_RPC_URL=                # Solana mainnet RPC (required for read/simulate/send)
# Source/destination Kamino Earn vault addresses (the wallet's own positions).
# Both must be set for the execution path to run; funds only move between these.
KAMINO_FROM_VAULT=
KAMINO_TO_VAULT=
KAMINO_MOVE_USD=1              # amount to move in USDC (minimal $1 for first send)
SOLANA_SLOT_MS=450            # approx slot duration for klend slot math

# ── HTTP server ──────────────────────────────────────────────────────────────
PORT=3000
RAILWAY_PUBLIC_DOMAIN=         # set by Railway; used in the agent card URL
INVESTX_PUBLIC_URL=            # public base URL when not on Railway
