{
  "name": "investx-for-agents",
  "version": "0.1.0",
  "description": "Non-custodial smart-money-following DeFi rebalance agent (R&D). Reads DeFiLlama + Nansen directly, records every decision to an ERC-8004 agentId. No payment/signing dependencies.",
  "main": "dist/index.js",
  "scripts": {
    "build": "rm -rf dist && tsc",
    "start": "npm run build && node dist/index.js",
    "dev": "ts-node src/index.ts",
    "run-now": "ts-node src/index.ts --run-now",
    "dry-run": "ts-node src/scripts/dry-run.ts"
  },
  "dependencies": {
    "dotenv": "16.4.7",
    "node-cron": "3.0.3",
    "typescript": "5.7.3",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "22.10.7",
    "@types/node-cron": "3.0.11",
    "ts-node": "10.9.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
